# ============================================================
# QUERY SERVICES - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your actual values

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=4001
NODE_ENV=development

# ============================================================
# DATABASE - MONGODB ATLAS
# ============================================================
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
# Get your connection string from MongoDB Atlas:
# 1. Go to MongoDB Atlas Dashboard
# 2. Click "Connect"
# 3. Choose "Drivers" / "Node.js"
# 4. Copy the connection string
# 5. Replace <username>, <password>, and database name

MONGODB_URI=# ============================================================
# REDIS CACHE
# ============================================================
# Format: redis://[:password]@host:port
# Get your connection URL from Redis Cloud:
# 1. Go to Redis Cloud Dashboard
# 2. Click on your database
# 3. Copy the "Redis CLI" connection string
# 4. Format it as: redis://default:password@host:port

REDIS_URL=
# ============================================================
# JWT AUTHENTICATION
# ============================================================
# Secret key for signing JWT tokens
# Use a strong, random string (min 32 characters recommended)
# Generate one: openssl rand -base64 32

JWT_SECRET=
JWT_EXPIRE=

# ============================================================
# RABBITMQ MESSAGE QUEUE
# ============================================================
# For local development:
RABBITMQ_URL=

# For cloud deployment (e.g., CloudAMQP):
# RABBITMQ_URL=amqp://username:password@host:port/vhost

QUEUE_NAME=query_queue

# ============================================================
# OPTIONAL - LOCAL MONGODB AUTHENTICATION
# ============================================================
# Only use these if running local MongoDB with authentication
# Leave empty if using MongoDB Atlas or local without auth

MONGODB_USER=
MONGODB_PASSWORD=
